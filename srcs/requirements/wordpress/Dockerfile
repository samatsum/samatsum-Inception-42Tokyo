# ==============================================================================
# FROM    : ベースイメージの指定。コンテナの土台（OSや基本環境）を決める。
#           ※原則としてDockerfileの先頭に記述する。
#
# EXPOSE  : コンテナが使用する予定のポートを「宣言」する。（ドキュメント的役割）
#           ※これ単体では外のネットワークとは繋がらず、docker-composeの `ports` とセットで機能する。
#
# RUN     : イメージの【ビルド時】に実行されるコマンド。
#           ※実行するたびに新しい「レイヤー（地層）」が作られイメージサイズ（空間計算量）が増加する。
#             そのため、関連する処理は `&&` で繋ぎ、1つのRUNにまとめるのがベスto。
#
# COPY    : ホスト（手元のPC）のファイルを、コンテナイメージ内に【ビルド時】にコピーする。
#
# ARG     : 【ビルド時】のみ使用できる一時的な変数。コンテナ起動後には消滅する。
#
# ENV     : 【コンテナ起動後】もOS内に残り続ける環境変数。アプリケーションの動作設定などに使う。
#
# WORKDIR : 以降の RUN, COPY, CMD などを実行する際の「基準ディレクトリ（作業場所）」を指定する。
#           ※ `RUN cd /path` と書いても次のRUNには引き継がれないため、ディレクトリ移動は必ずこれを使う。
#
# CMD     : コンテナが【起動した瞬間】にデフォルトで実行される主役プロセス（PID 1）。
#           ※1つのDockerfileにつき最後に1つだけ有効。このプロセスが終了すると、コンテナ自体も終了する。
# ==============================================================================

FROM debian:bookworm

RUN apt update && apt upgrade -y && apt install -y \
    php8.2 \
    php8.2-fpm \
    php8.2-mysql \
    php8.2-redis \
    curl \
    wget \
    unzip \
    default-mysql-client


COPY conf/www.conf /etc/php/8.2/fpm/pool.d/www.conf
COPY tools/script.sh .

# PHP-FPMがプロセス管理用のソケットやPIDファイルを置くためのディレクトリを作成。
# WordPressのプラグインディレクトリを事前作成し、Redisキャッシュプラグインをダウンロード＆解凍。
RUN mkdir -p /run/php && \
    mkdir -p /var/www/html/wp-content/plugins && \
    wget -P /var/www/html/wp-content/plugins/ https://downloads.wordpress.org/plugin/redis-cache.2.5.4.zip && \
    cd /var/www/html/wp-content/plugins/ && \
    unzip redis-cache.2.5.4.zip && \
    rm redis-cache.2.5.4.zip

RUN chmod +x script.sh

# コンテナ起動時にPID 1として実行されるメインプロセス
CMD ["./script.sh"]

# 豆知識
# WordPress...コンテナが消えると処理途中の状態も消える
# ==============================================================================
# 【根本原理：WordPress（PHP-FPM）とは何か？】
# システムの「コンテンツ生成工場（動的アプリケーション層）」です。
# NGINXから渡されたリクエスト（FastCGIプロトコル）に基づき、PHPコードを実行して
# DBからデータを引き出し、HTMLを動的に組み立てます。
# プロセス自体は「ステートレス（記憶を持たない使い捨ての作業員）」に徹します。
# 
# [応用機能（今回の課題外）]
# 世界シェア最大のCMS（コンテンツ管理システム）であり、最大の武器は巨大なエコシステムです。
# 現代のモダンな開発では、画面表示機能を持たずJSONデータだけを返す「REST API」として稼働させ、
# ReactやVue.jsなどの別フロントエンドと連携する「Headless CMS」というアーキテクチャの
# 裏側（バックエンド）としても広く利用されています。
# ==============================================================================