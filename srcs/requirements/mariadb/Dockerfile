# ==============================================================================
# FROM    : ベースイメージの指定。コンテナの土台（OSや基本環境）を決める。
#           ※原則としてDockerfileの先頭に記述する。
#
# EXPOSE  : コンテナが使用する予定のポートを「宣言」する。（ドキュメント的役割）
#           ※これ単体では外のネットワークとは繋がらず、docker-composeの `ports` とセットで機能する。
#
# RUN     : イメージの【ビルド時】に実行されるコマンド。
#           ※実行するたびに新しい「レイヤー（地層）」が作られイメージサイズ（空間計算量）が増加する。
#             そのため、関連する処理は `&&` で繋ぎ、1つのRUNにまとめるのがベスto。
#
# COPY    : ホスト（手元のPC）のファイルを、コンテナイメージ内に【ビルド時】にコピーする。
#
# ARG     : 【ビルド時】のみ使用できる一時的な変数。コンテナ起動後には消滅する。
#
# ENV     : 【コンテナ起動後】もOS内に残り続ける環境変数。アプリケーションの動作設定などに使う。
#
# WORKDIR : 以降の RUN, COPY, CMD などを実行する際の「基準ディレクトリ（作業場所）」を指定する。
#           ※ `RUN cd /path` と書いても次のRUNには引き継がれないため、ディレクトリ移動は必ずこれを使う。
#
# CMD     : コンテナが【起動した瞬間】にデフォルトで実行される主役プロセス（PID 1）。
#           ※1つのDockerfileにつき最後に1つだけ有効。このプロセスが終了すると、コンテナ自体も終了する。
# CMD:「もしユーザーが何も指定せずにコンテナを起動したら、とりあえずこれを実行してね」という弱い指定
# ENTRYPOINT:「このコンテナが起動した時は、何が何でも絶対にこのスクリプトをPID 1として実行する」という強い指定
# ==============================================================================

FROM debian:bookworm

# MariaDBの標準プロトコルポートである3306番を使用することを明示。
EXPOSE 3306

RUN apt update && apt upgrade -y && apt install -y mariadb-server && \
    rm -rf /var/lib/mysql/*

COPY conf/50-server.cnf /etc/mysql/mariadb.conf.d/.
COPY tools/script.sh .

# MariaDBプロセスはセキュリティ確保のため、
# rootではなく `mysql` という専用の制限付きユーザーで稼働する.
# 事前にディレクトリの所有権(chown)を `mysql` に渡しておかないと、
# コンテナ起動時に「ファイルが書き込めない」とエラーになり強制終了してしまう。
RUN mkdir -p /run/mysqld && \
    chown mysql:mysql /run/mysqld && \
    chmod +x script.sh

#CMD ["./script.sh"]
ENTRYPOINT ["/script.sh"]

# MariaDBはユーザーデータや投稿内容を永続化し、
# システムが再起動しても状態を復元する責任を持ちます。
# ==============================================================================
# 【根本原理：MariaDBとは何か？】
# システムの「堅牢な金庫番（ステートフルな永続化・データ層）」です。
# MySQLから派生したオープンソースのRDBMS（リレーショナルデータベース）であり、
# ユーザー情報や投稿内容など、システム全体の「記憶」を物理ディスクに安全に保存・復元します。
# アプリ層が全滅しても、この層のデータ（Volume）さえ無事ならシステムは蘇ります。
# 
# [応用機能（今回の課題外）]
# 今回は単一ノード（1台）での稼働ですが、実運用ではデータの損失を防ぐ「レプリケーション（主従複製）」や、
# 複数台のサーバーで処理とデータを分散させる「Galera Cluster（分散クラスタリング）」を構築し、
# 空間計算量（容量・冗長性）と高可用性を極限まで高めるためのインフラの心臓部となります。
# ==============================================================================