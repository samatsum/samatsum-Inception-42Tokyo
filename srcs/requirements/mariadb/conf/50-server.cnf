[server]

[mysqld]
# ==============================================================================
# 1. プロセスと権限の設定
# ==============================================================================
user                    = root
pid-file                = /run/mysqld/mysqld.pid

# ==============================================================================
# 2. ネットワーク設定（スタック横断的な接続）
# ==============================================================================
# Linuxカーネルに対し「TCP 3306番ポートで、すべてのネットワークインターフェース（0.0.0.0）
# からの接続要求（SYNパケット）を待ち受けろ」と命令
port                    = 3306
bind-address            = 0.0.0.0

# ==============================================================================
# 3. ディレクトリとデータ保存（堅牢性と永続化）
# ==============================================================================
basedir                 = /usr
# コンテナが破壊されても、このディレクトリを通ってホスト側に書き込まれたデータは消えない.
# docker-compose.yml で、ホストOS側のディレクトリ（ボリューム）にマウント（直結）されるので。
datadir                 = /var/lib/mysql 
tmpdir                  = /tmp

# ==============================================================================
# 4. 文字セットと照合順序（多言語対応）
# ==============================================================================
character-set-server    = utf8mb4
collation-server        = utf8mb4_general_ci

[embedded]
[mariadb]
[mariadb-10.11]